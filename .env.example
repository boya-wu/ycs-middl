# Supabase 本地開發設定
# 金鑰請勿寫入版本庫；執行 `npx supabase status` 複製 JWT 格式的 anon / service_role。
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# PIP 自我檢查：true 時允許手動輸入卡號；生產環境請省略或設 false（僅接受讀卡機快速輸入）
NEXT_PUBLIC_PIP_TEST_MODE=true

# 如果你有後端需要用到萬用權限（選填）
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
